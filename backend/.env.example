# .env.example — copy to .env and fill in real values
# [SECURITY] Never commit .env — only commit this .env.example file

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-output-of-secrets-token-hex-32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=false

ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=sqlite:///./ecotrack.db

# Obtain from https://console.groq.com/keys
GROQ_API_KEY=gsk_replace-with-your-groq-key